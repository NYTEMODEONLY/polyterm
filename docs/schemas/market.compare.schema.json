{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolyTerm market.compare response",
  "description": "Stable envelope for agent-native market comparison and divergence analysis.",
  "type": "object",
  "required": ["schema_version", "success", "data", "error", "meta"],
  "properties": {
    "schema_version": {"type": "string"},
    "success": {"type": "boolean"},
    "error": {"type": ["string", "null"]},
    "meta": {"type": "object"},
    "data": {
      "type": "object",
      "required": ["query", "count", "hours", "markets", "pairwise", "headline", "divergence_summary", "evidence_sources", "quality_flags", "generated_at"],
      "properties": {
        "query": {"type": "array", "items": {"type": "string"}},
        "count": {"type": "integer"},
        "hours": {"type": "integer"},
        "markets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "input": {"type": "string"},
              "gamma_market_id": {"type": ["string", "number", "null"]},
              "slug": {"type": ["string", "null"]},
              "condition_id": {"type": ["string", "null"]},
              "clob_token_ids": {"type": "array", "items": {"type": "string"}},
              "title": {"type": ["string", "null"]},
              "probability": {"type": ["number", "null"]},
              "volume": {"type": ["number", "null"]},
              "volume_24h": {"type": ["number", "null"]},
              "liquidity": {"type": ["number", "null"]},
              "move": {"type": "object"},
              "orderbook": {"type": "object"},
              "history_points": {"type": "integer"}
            }
          }
        },
        "pairwise": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "left_slug": {"type": ["string", "null"]},
              "right_slug": {"type": ["string", "null"]},
              "probability_gap": {"type": "number"},
              "liquidity_gap": {"type": "number"},
              "volume_gap": {"type": "number"},
              "combined_probability": {"type": "number"}
            }
          }
        },
        "headline": {"type": "string"},
        "divergence_summary": {"type": "object"},
        "evidence_sources": {"type": "array", "items": {"type": "object"}},
        "quality_flags": {"type": "array", "items": {"type": "string"}},
        "generated_at": {"type": "string"}
      }
    }
  }
}
